<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>The Coffee Lab: Final Edition</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #F5EFEB; color: #4A3B32; max-width: 1200px; margin: 0 auto; padding: 20px; box-sizing: border-box; }
        h1, h2, h3, h4 { color: #3E2723; margin-top: 0; }
        .pos { color: #27AE60; font-weight: bold; }
        .neg { color: #C0392B; font-weight: bold; }
        .large-text { font-size: 1.2em; }
        
        *:focus-visible { outline: 3px solid #D35400; outline-offset: 3px; border-radius: 4px; }
        
        .dashboard { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; background: #2C3E50; color: #F8F9F9; padding: 20px; border-radius: 12px; box-shadow: 0 6px 12px rgba(0,0,0,0.15); margin-bottom: 20px; align-items: center; border: 4px solid #5D4037; }
        .dash-rival-text { color: #FADBD8; }
        .buzz-text { color: #F1C40F; font-weight: bold; }
        
        .progress-bar-container { grid-column: span 5; }
        .progress-bar { background: #D6CCC2; height: 14px; border-radius: 7px; overflow: hidden; margin-top: 5px; position: relative; border: inset 1px #B0A094; }
        .fill-player { background: #8D6E63; height: 100%; width: 0%; transition: width 0.5s ease-out; position: absolute; z-index: 2; opacity: 0.95; }
        .fill-rival { background: #E74C3C; height: 100%; width: 0%; transition: width 0.5s ease-out; position: absolute; z-index: 1; opacity: 0.7; }
        .progress-labels { font-size: 0.7em; color: #BDC3C7; display: flex; justify-content: space-between; margin-top: 4px; }
        
        .forecast-container { display: flex; gap: 10px; margin-bottom: 20px; }
        .forecast-day { flex: 1; text-align: center; padding: 12px; border-radius: 10px; background: #EAE0D5; color: #5D4037; font-weight: 600; border: 2px solid transparent; transition: 0.3s; }
        .forecast-day.active { background: #D35400; color: white; transform: scale(1.05); border-color: #A04000; box-shadow: 0 4px 8px rgba(211, 84, 0, 0.3); }
        .weather-temp { font-size: 0.75em; opacity: 0.9; display: block; margin-top: 4px; }

        .main-layout { display: grid; grid-template-columns: 1fr 1.6fr; gap: 20px; }
        .panel { background: #FFFFFF; padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(93, 64, 55, 0.08); margin-bottom: 20px; border: 1px solid #F0E6D2; }
        .panel-header { background: #5D4037; color: white; margin: -25px -25px 15px -25px; padding: 15px 25px; border-radius: 15px 15px 0 0; }
        
        .cam-box { background: #1A1A1A; height: 70px; border-radius: 8px; position: relative; overflow: hidden; border: 3px solid #333; margin-bottom: 20px; box-shadow: inset 0 0 10px rgba(0,0,0,0.8); }
        .cam-label { position: absolute; top: 5px; left: 8px; color: #E74C3C; font-size: 0.7em; font-family: monospace; font-weight: bold; z-index: 10; animation: blink 1s infinite; }
        .emoji-customer { position: absolute; font-size: 1.8em; bottom: 5px; left: -40px; }
        .emoji-reaction { position: absolute; font-size: 0.6em; top: -15px; left: 5px; opacity: 0; }
        
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
        @keyframes walkAcross { 0% { left: -40px; transform: scaleX(1); } 100% { left: 105%; transform: scaleX(1); } }
        @keyframes walkInAndLeave { 0% { left: -40px; transform: scaleX(1); } 40% { left: 45%; transform: scaleX(1); } 50% { left: 45%; transform: scaleX(-1); } 100% { left: -40px; transform: scaleX(-1); } }
        @keyframes floatUp { 0% { opacity: 1; transform: translateY(0); } 100% { opacity: 0; transform: translateY(-25px); } }

        .control-row { margin-bottom: 12px; border-bottom: 1px dashed #D6CCC2; padding-bottom: 8px; }
        .control-row.no-border { border-bottom: none; }
        .control-label { display: flex; justify-content: space-between; font-weight: bold; font-size: 0.85em; color: #5D4037; width: 100%; cursor: pointer; }
        input[type="range"] { width: 100%; accent-color: #D35400; cursor: pointer; }
        input[type="number"], input[type="text"] { border: 2px solid #D6CCC2; border-radius: 6px; color: #4A3B32; padding: 10px; font-weight: bold; font-size: 1.1em; width: 100%; box-sizing: border-box; }
        
        .action-btn { background: #D35400; color: white; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; transition: 0.2s; width: 100%; padding: 15px; font-size: 1.1em; }
        .sys-btn { background: #5C6A6B; color: white; border: none; padding: 6px 10px; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 0.75em; flex: 1; margin: 2px; }
        .sys-btn.green { background: #1E8449; } 
        .sys-btn.yellow { background: #D4AC0D; color: #3E2723; } 
        .sys-btn.red { background: #A93226; } 
        
        .cost-card { background: #FDFBF7; border: 2px solid #D6CCC2; border-radius: 10px; padding: 15px; margin-top: 15px; font-size: 0.9em; }
        .metric-box { background: #FFFFFF; border: 1px solid #EAE0D5; padding: 15px; border-radius: 10px; margin: 15px 0; font-size: 0.9em; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); }
        .metric-row { display: flex; justify-content: space-between; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px dashed #D6CCC2; }
        .metric-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .quote-box { font-style: italic; color: #5D4037; background: #FFF3E0; padding: 15px; border-left: 4px solid #D35400; text-align: left; margin-bottom: 15px; font-size: 0.9em; border-radius: 4px; }
        
        .tabs { display: flex; gap: 5px; margin-bottom: 15px; overflow-x: auto; }
        .tab-btn { flex: 1; padding: 12px; border: none; background: #EAE0D5; border-radius: 8px; cursor: pointer; font-size: 0.9em; font-weight: bold; color: #5D4037; white-space: nowrap; }
        .tab-btn.active { background: #5D4037; color: #F5EFEB; }
        .tab-btn.rival-tab { background: #FADBD8; color: #C0392B; }
        .tab-btn.rival-tab.active { background: #C0392B; color: white; }
        .tab-btn.biz-tab { background: #D4E6F1; color: #2980B9; }
        .tab-btn.biz-tab.active { background: #2980B9; color: white; }
        
        .research-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .research-item { background: #FDFBF7; padding: 15px; border-radius: 10px; border: 2px solid #EAE0D5; }
        .tier-btn { width: 100%; margin: 5px 0; padding: 10px; font-size: 0.8em; cursor: pointer; background: #8D6E63; color: white; border: none; border-radius: 6px; font-weight: bold; }
        .tier-btn:disabled { opacity: 0.4; cursor: not-allowed; }
        .reveal-math { font-size: 1.1em; color: #C0392B; font-weight: bold; margin-top: 10px; background: #FDEDEC; padding: 10px; border-radius: 6px; border: 1px dashed #E74C3C; text-align: center; font-family: monospace; }
        
        .data-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 0.85em; background: white; }
        .data-table th, .data-table td { border: 1px solid #D6CCC2; padding: 6px; text-align: center; }
        .data-table th { background: #EAE0D5; }

        .sabotage-box { background: #FDEDEC; border: 2px solid #E74C3C; padding: 20px; border-radius: 10px; }
        .business-box { background: #EAF2F8; border: 2px solid #2980B9; padding: 20px; border-radius: 10px; text-align: center; }
        
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(62, 39, 35, 0.85); z-index: 100; justify-content: center; align-items: center; overflow-y: auto; padding: 20px; box-sizing: border-box; }
        .modal-content { background: #FDFBF7; padding: 30px; border-radius: 15px; max-width: 500px; width: 100%; position: relative; border-top: 10px solid #D35400; margin: auto; }
        .modal-content.large-modal { max-width: 950px; }
        .close-x { position: absolute; top: 15px; right: 20px; font-size: 1.5em; font-weight: bold; color: #5D4037; cursor: pointer; line-height: 1; background: transparent; border: none; padding: 5px; }
        
        .table-container { max-height: 250px; overflow-y: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 0.85em; text-align: center; }
        th { background: #5D4037; color: #F5EFEB; padding: 12px 8px; position: sticky; top: 0; cursor: pointer; user-select: none; }
        
        .math-highlight { font-size: 1.2em; font-family: monospace; font-weight: bold; background: #eee; padding: 4px 8px; border-radius: 5px; display: inline-block; margin: 8px 0; }
        
        .footer-container { display: flex; justify-content: center; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 2px dashed #D6CCC2; flex-wrap: wrap; }
        .nav-link { display: inline-block; padding: 10px 20px; font-size: 0.9em; font-weight: bold; text-decoration: none; cursor: pointer; border: 2px solid #D6CCC2; border-radius: 8px; transition: 0.2s; background: #FDFBF7; color: #5D4037; }
        .nav-link:hover { border-color: #5D4037; background: #EAE0D5; }
        .nav-link.tech { border-color: transparent; background: transparent; color: #5C6A6B; font-weight: normal; }
        .nav-link.tech:hover { color: #5D4037; text-decoration: underline; background: transparent; border-color: transparent; }

        @media (max-width: 850px) {
            .main-layout { grid-template-columns: 1fr; }
            .dashboard { grid-template-columns: repeat(3, 1fr); }
            .progress-bar-container { grid-column: span 3; }
            .research-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div id="welcomeModal" class="modal-overlay" style="background: #3E2723;" role="dialog" aria-modal="true" aria-labelledby="welcomeTitle">
        <div class="modal-content large-modal" style="text-align:center; border-top-color: #27AE60;" tabindex="-1" id="welcomeContent">
            <h1 id="welcomeTitle" style="color:#D35400;">☕ Welcome to The Coffee Lab</h1>
            <p style="text-align:left; font-size:1.05em; line-height:1.6; color:#4A3B32;">You've just taken over a small, independent cafe right across the street from the corporate giant, <strong>Roaster Co.</strong></p>
            <p style="text-align:left; font-size:1.05em; line-height:1.6; color:#4A3B32;">Roaster Co. has a massive marketing budget and a team of corporate analysts. You have a leaky espresso machine and a lot of determination.</p>
            
            <div class="quote-box" style="margin: 20px 0; font-size: 1.05em;">
                <strong>The Stakes:</strong> The landlord is selling the building. The first shop to reach <strong>$15,000</strong> in the bank gets to buy the property. If Roaster Co. wins, you're out of a job.
            </div>
            
            <p style="text-align:left; font-size:1.05em; line-height:1.6; color:#4A3B32;">You can't afford expensive focus groups, so you'll have to analyze your daily feedback, perfect your recipes, and run Roaster Co. out of town.</p>
            
            <div style="margin-top: 25px;">
                <button class="action-btn" style="background:#27AE60; max-width: 300px; margin: 0 auto; display: block;" onclick="startGame()">Start Brewing</button>
            </div>
        </div>
    </div>

    <div id="winModal" class="modal-overlay" style="background: #1B4F72;">
        <div class="modal-content large-modal" style="text-align:center; border-top-color: #F1C40F;">
            <h1 style="color:#F39C12; font-size:2.5em;">🏆 VICTORY!</h1>
            <p style="font-size:1.2em;">You reached <strong>$15,000</strong> and bought the building!</p>
            <div class="metric-box" style="background:#FEF9E7; border: 2px solid #F1C40F; padding:20px; text-align:left;">
                <p><strong>Total Days to Win:</strong> <span id="winDays">0</span></p>
                <p><strong>First Perfect Recipe:</strong> <span id="winRecipeDay">Not found</span></p>
                <p><strong>First Perfect Price:</strong> <span id="winPriceDay">Not found</span></p>
            </div>
            <button class="action-btn" onclick="hardReset()" style="margin-top: 15px;">Start a New Game</button>
        </div>
    </div>

    <div id="lossModal" class="modal-overlay" style="background: #4A235A;">
        <div class="modal-content large-modal" style="text-align:center; border-top-color: #C0392B;">
            <h1 style="color:#C0392B; font-size:2.5em;">📉 FORCED CLOSURE</h1>
            <p style="font-size:1.2em;">Roaster Co. reached <strong>$15,000</strong> first and bought the building.</p>
            <button class="action-btn" style="background:#C0392B;" onclick="hardReset()">Try Again</button>
        </div>
    </div>

    <div id="mathGuideModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="mathGuideTitle">
        <div class="modal-content" style="border-top-color: #2980b9;" tabindex="-1" id="mathGuideContent">
            <button class="close-x" aria-label="Close Math Guide" onclick="toggleModal('mathGuideModal', false)">&times;</button>
            <h2 id="mathGuideTitle" style="color:#2C3E50; margin-top:0;">🧮 Math Formulas Guide</h2>
            <div style="font-size: 0.9em; color: #4A3B32; text-align: left; line-height: 1.6;">
                <p>Use these algebraic concepts to find the peak (vertex) of the Taste Score curve!</p>
                <h4 style="color:#2980b9; margin-bottom: 5px;">1. Using Symmetry (Midpoint)</h4>
                <p style="margin-top:0;">Parabolas are perfectly symmetrical. If you have two points that produce the exact same y-value, the vertex is perfectly in the middle of their x-values.</p>
                <div class="math-highlight">x = (x&#8321; + x&#8322;) / 2</div>
                <h4 style="color:#2980b9; margin-bottom: 5px;">2. Using Standard Form</h4>
                <p style="margin-top:0;">If you research a recipe and get standard form: <strong>y = ax&sup2; + bx + c</strong>, you can use the vertex formula to find the peak.</p>
                <div class="math-highlight">x = -b / (2a)</div>
                <p>Plug that x-value back into the equation to find your maximum y-value (Taste Score)!</p>
                <h4 style="color:#2980b9; margin-bottom: 5px;">3. Using Vertex Form</h4>
                <p style="margin-top:0;">If you purchase the highest tier of research, you get vertex form: <strong>y = a(x - h)&sup2; + k</strong>. The peak is given directly to you in the equation!</p>
                <div class="math-highlight">Vertex = (h, k)</div>
                <p>The <strong>h</strong> is the perfect slider amount, and <strong>k</strong> is the Taste Score it produces.</p>
            </div>
            <button class="action-btn" style="background:#2980b9; margin-top:15px;" onclick="toggleModal('mathGuideModal', false)">Back to Lab</button>
        </div>
    </div>

    <div id="managerGuideModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="managerGuideTitle">
        <div class="modal-content" style="border-top-color: #27AE60;" tabindex="-1" id="managerGuideContent">
            <button class="close-x" aria-label="Close Manager's Guide" onclick="toggleModal('managerGuideModal', false)">&times;</button>
            <h2 id="managerGuideTitle" style="color:#27AE60; margin-top:0;">📖 Manager's Rulebook</h2>
            <div style="font-size: 0.9em; color: #4A3B32; text-align: left; line-height: 1.5;">
                <p><strong>Goal:</strong> Reach $15,000 in your Bank before your rival, Roaster Co. does.</p>
                <p><strong>☕ Brewing & Taste:</strong> Set your Temperature, Sweetness, and Intensity sliders. The better the combination matches the weather, the higher your Taste Score. High Taste Scores attract more potential customers.</p>
                <p><strong>🌦️ Weather & Demand:</strong> Customers prefer different flavors depending on if it is Sunny, Heatwave, or Rainy. Pay attention to the forecast to predict demand!</p>
                <p><strong>💵 Pricing & Conversion:</strong> You set the price of the cup. If the price is too high for the Taste Score, customers will "walk away" without buying. Price gouging (charging over $20) will trigger a city-wide boycott.</p>
                <p><strong>📉 Expenses & Beans:</strong> You pay $150 in fixed rent every day. You also pay Marginal Costs for the ingredients in each cup sold. Buying 500 Bulk Beans ($100) lowers your marginal cost significantly, but they go stale in 5 days.</p>
                <p><strong>📈 Buzz & Blogs:</strong> Stringing together profitable days with high Taste Scores generates "Buzz," which brings extra daily traffic. Incredible recipes on Rainy Days may attract powerful Coffee Bloggers.</p>
                <p><strong>🚪 Closing Shop:</strong> If the weather is terrible and you can't afford a loss, you can choose to Close Shop. You will still pay $150 rent and beans will still age, but you will safely keep your Buzz streak alive!</p>
            </div>
            <button class="action-btn" style="background:#27AE60; margin-top:15px;" onclick="toggleModal('managerGuideModal', false)">Let's Brew</button>
        </div>
    </div>

    <div id="upgradeModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="upgradeModalTitle">
        <div class="modal-content large-modal" style="border-top-color: #8E44AD;" tabindex="-1" id="upgradeModalContent">
            <button class="close-x" aria-label="Close Research Lab" onclick="toggleModal('upgradeModal', false)">&times;</button>
            <h1 id="upgradeModalTitle" style="color:#8E44AD; margin-bottom: 5px;">🔬 Advanced Research Lab</h1>
            <p style="margin-top: 0; color: #5D4037;">Purchase data and formulas to perfectly optimize your shop.</p>
            
            <div class="tabs" role="tablist" aria-label="Research Categories">
                <button role="tab" aria-selected="true" class="tab-btn active" id="tabSunny" onclick="switchResearchTab('Sunny')">☀️ Sunny</button>
                <button role="tab" aria-selected="false" class="tab-btn" id="tabHeatwave" onclick="switchResearchTab('Heatwave')">🔥 Heatwave</button>
                <button role="tab" aria-selected="false" class="tab-btn" id="tabRainy" onclick="switchResearchTab('Rainy')">🌧️ Rainy</button>
                <button role="tab" aria-selected="false" class="tab-btn rival-tab" id="tabRival" onclick="switchResearchTab('Rival')">🕵️ Espionage</button>
                <button role="tab" aria-selected="false" class="tab-btn biz-tab" id="tabBusiness" onclick="switchResearchTab('Business')">📈 Business</button>
            </div>

            <div id="researchContainer" class="research-grid" aria-live="polite"></div>
            
            <div id="sabotageContainer" style="display:none;" class="sabotage-box">
                <h4 style="color:#C0392B;">Leak Fake Recipe to Roaster Co.</h4>
                <label for="sabotageTemp" style="font-size:0.85em;">Give them a fake <strong>Temperature (x)</strong> for today's weather: <span id="sabWeatherUI" style="font-weight:bold;"></span></label>
                <br>
                <input type="number" id="sabotageTemp" style="width:100px; padding:10px; font-size:1.1em; font-weight:bold; border: 1px solid #C0392B; margin-top:5px;" value="0">
                <p style="font-size:0.8em; color:#922B21; margin-top:10px;">They won't believe recipes with a Taste Score under <span id="sabThresholdUI" style="font-weight:bold; font-size:1.2em;"></span>.</p>
            </div>

            <div id="businessContainer" style="display:none;" class="business-box" aria-live="polite"></div>

            <button class="action-btn" style="background:#5D4037; margin-top:20px;" onclick="toggleModal('upgradeModal', false)">Return to Shop</button>
        </div>
    </div>

    <div id="reportModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="reportModalTitle">
        <div class="modal-content" style="text-align: center;" tabindex="-1" id="reportModalContent">
            <h2 id="reportModalTitle" style="margin-top:0;">Closing Time</h2>
            <div id="modalWeather" style="font-weight:bold; color:#8D6E63; margin-bottom:15px;" aria-live="polite"></div>
            
            <div id="modalSnobBlog" style="display:none; background:#E8DAEF; color:#6C3483; padding:10px; border-radius:8px; margin-bottom:15px; font-weight:bold; font-size:0.9em; border:1px dashed #9B59B6;" aria-live="polite"></div>
            
            <div id="modalBadBlog" style="display:none; background:#FDEDEC; color:#C0392B; padding:10px; border-radius:8px; margin-bottom:15px; font-weight:bold; font-size:0.9em; border:1px dashed #E74C3C;" aria-live="polite">
                📉 A local coffee influencer was horrified by your rainy day brew! A scathing review just went live. Expect a drop in customers tomorrow.
            </div>

            <div id="modalPriceGouge" style="display:none; background:#F5B041; color:#7E5109; padding:10px; border-radius:8px; margin-bottom:15px; font-weight:bold; font-size:0.9em; border:1px dashed #B9770E;" aria-live="polite">
                🚨 SCANDAL! Your outrageous prices went viral online! You are being boycotted. Expect an empty shop tomorrow! (-150 Customers)
            </div>
            
            <div class="quote-box" id="modalQuote" aria-live="polite"></div>

            <div class="metric-box" style="text-align: left;" aria-live="polite">
                <div class="metric-row"><strong>Taste Score:</strong> <span id="modalTaste" style="font-size:1.1em; font-weight:bold;">0</span></div>
                <div class="metric-row"><span>Potential Customers:</span> <span id="modalPot">0</span></div>
                
                <div class="metric-row" id="walkawayStandard"><span class="neg">Total Walkaways:</span> <span id="modalWalk" class="neg">0</span></div>
                
                <div class="metric-row" id="walkawayAdvancedTaste" style="display:none;"><span class="neg" style="opacity: 0.8;">↳ Walked Away (Didn't like recipe):</span> <span id="modalWalkTaste" class="neg">0</span></div>
                <div class="metric-row" id="walkawayAdvancedPrice" style="display:none; padding-bottom: 8px; border-bottom: 1px dashed #D6CCC2;"><span class="neg" style="opacity: 0.8;">↳ Walked Away (Price too high):</span> <span id="modalWalkPrice" class="neg">0</span></div>

                <div class="metric-row" style="border-top: 1px solid #EAE0D5; padding-top: 8px; margin-top: 8px;"><span class="pos">Actual Sales:</span> <span id="modalSales" class="pos">0</span></div>
            </div>

            <button class="sys-btn" id="toggleBreakdownBtn" style="width: 100%; margin: 5px 0 15px 0; background: #BDC3C7; color: #3E2723; padding: 10px; display: none;" aria-expanded="false" aria-controls="financialBreakdown" onclick="toggleBreakdown()">📊 Show Financial Breakdown</button>
            
            <div id="financialBreakdown" style="display:none; background:#FDFBF7; border: 1px solid #D6CCC2; padding: 15px; border-radius: 8px; font-size: 0.85em; text-align: left; margin-bottom: 15px;" aria-live="polite">
                <div class="metric-row"><span>Gross Revenue:</span> <strong class="pos" id="modalRev">$0.00</strong></div>
                <div class="metric-row"><span>Ingredient Costs:</span> <strong class="neg" id="modalIngCost">-$0.00</strong></div>
                <div class="metric-row"><span>Daily Rent:</span> <strong class="neg" id="modalRentCost">-$150.00</strong></div>
                <div class="metric-row" style="border-top: 1px dashed #D6CCC2; margin-top: 4px; padding-top: 8px;"><span>Total Expenses:</span> <strong class="neg" id="modalTotalExp">-$150.00</strong></div>
            </div>

            <div class="metric-box" style="background:#EAFBFF; border-color:#2980b9; text-align: left;" aria-live="polite">
                <div class="metric-row" id="modalDonorRow" style="display:none; color:#8E44AD;">
                    <span>Angel Donor Grant:</span> <strong id="modalDonor">+$0.00</strong>
                </div>
                <div class="metric-row"><strong>Your Net Profit:</strong> <span id="modalNet" class="large-text">$0.00</span></div>
                <div class="metric-row"><strong class="neg">Rival Profit:</strong> <span id="modalRivalNet" class="neg">$0.00</span></div>
