    <script>
        const defaultState = {
            shopName: "The Math Mug", rivalMomentum: 0, bank: 0, rivalBank: 0, day: 1, forecast: [], weatherData: {},
            unlocked: { 
                Sunny: { t: {2:false,3:false,4:false}, s: {2:false,3:false,4:false}, i: {2:false,3:false,4:false} }, 
                Heatwave: { t: {2:false,3:false,4:false}, s: {2:false,3:false,4:false}, i: {2:false,3:false,4:false} }, 
                Rainy: { t: {2:false,3:false,4:false}, s: {2:false,3:false,4:false}, i: {2:false,3:false,4:false} }, 
                marketResearch: false, financialBreakdown: false
            },
            savedRecipes: { Sunny: null, Heatwave: null, Rainy: null },
            activeResearchTab: 'Sunny', buzzStreak: 0, maxBuzz: 0, winGoal: 15000, rent: 150, ingredientCost: 0.50, bulkBeans: 0, bulkDays: 0,
            sabotageSuccesses: 0, snobBlogBuff: 0, badBlogActive: false, priceGougeActive: false, snobRainyStreak: 0, ledgerData: [],
            sortCol: 'd', sortAsc: false, dayPerfectRecipe: null, dayPerfectPrice: null
        };

        let state = JSON.parse(JSON.stringify(defaultState));

        function rand(min, max, decimals = 1) { return +(Math.random() * (max - min) + min).toFixed(decimals); }

        function generateEquation(hMin, hMax, kMin, kMax, aMin, aMax) {
            let h = rand(hMin, hMax); let k = Math.floor(rand(kMin, kMax, 0)); let a = Math.floor(rand(aMin, aMax, 0));
            const calcY = (x) => +(a * Math.pow(x - h, 2) + k).toFixed(1);
            let secantPoints = []; let side = h > 5 ? -1 : 1;
            for(let i=3; i>=1; i--) { 
                let xVal = Math.max(0, Math.min(10, +(h + (side * i * 1.5)).toFixed(1)));
                secantPoints.push({ x: xVal, y: calcY(xVal) });
            }
            secantPoints.sort((a,b) => a.x - b.x);
            return { h, k, a, secantPoints, symPoints: [{ x: +(h - 3).toFixed(1), y: calcY(h - 3) }, { x: +(h + 3).toFixed(1), y: calcY(h + 3) }], std: `${a}x² ${(-2*a*h >= 0 ? '+'+(-2*a*h).toFixed(1) : (-2*a*h).toFixed(1))}x ${( (a*h*h+k) >= 0 ? '+'+(a*h*h+k).toFixed(1) : (a*h*h+k).toFixed(1))}` };
        }

        function initializeGame() {
            state.weatherData = {
                "Sunny": { t: generateEquation(4.5, 5.5, 45, 55, -2, -3), s: generateEquation(2.5, 3.5, 25, 35, -6, -8), i: generateEquation(4.5, 5.5, 18, 25, -15, -20), sens: 8, demand: 1.2, tempStr: "78°F" },
                "Heatwave": { t: generateEquation(0.5, 2.0, 60, 70, -4, -6), s: generateEquation(6.5, 8.0, 20, 30, -8, -12), i: generateEquation(2.5, 4.0, 45, 55, -10, -15), sens: 4, demand: 3.5, tempStr: "96°F" },
                "Rainy": { t: generateEquation(8.0, 9.5, 35, 45, -3, -5), s: generateEquation(4.5, 6.0, 35, 45, -5, -7), i: generateEquation(7.5, 9.0, 45, 55, -20, -25), sens: 14, demand: 1.1, tempStr: "52°F" }
            };
            state.forecast = ["Sunny", "Sunny", "Sunny", "Sunny", "Sunny"];
            for(let j=0; j<2; j++) { state.forecast.push(["Sunny","Heatwave","Rainy"][Math.floor(Math.random()*3)]); }
            
            if (state.day === 1) {
                toggleModal('welcomeModal', true);
            } else {
                updateUI();
            }
        }

        function startGame() {
            toggleModal('welcomeModal', false);
            updateUI();
        }

        function hardReset() {
            state = JSON.parse(JSON.stringify(defaultState));
            toggleModal('winModal', false);
            toggleModal('lossModal', false);
            document.getElementById('ledgerBody').innerHTML = '';
            initializeGame();
        }

        function toggleModal(id, show) { 
            const modal = document.getElementById(id);
            modal.style.display = show ? 'flex' : 'none'; 
            if (show) {
                const contentBox = modal.querySelector('.modal-content');
                if(contentBox) contentBox.focus();
            }
        }
        
        function toggleBreakdown() {
            const bd = document.getElementById('financialBreakdown');
            const btn = document.getElementById('toggleBreakdownBtn');
            if (bd.style.display === 'none') {
                bd.style.display = 'block';
                btn.innerText = '🙈 Hide Financial Breakdown';
                btn.setAttribute('aria-expanded', 'true');
            } else {
                bd.style.display = 'none';
                btn.innerText = '📊 Show Financial Breakdown';
                btn.setAttribute('aria-expanded', 'false');
            }
        }

        function openUpgrades() { 
            state.activeResearchTab = state.forecast[0];
            switchResearchTab(state.activeResearchTab);
            toggleModal('upgradeModal', true); 
        }

        function switchResearchTab(tab) {
            state.activeResearchTab = tab;
            document.querySelectorAll('.tab-btn').forEach(b => {
                b.classList.remove('active');
                b.setAttribute('aria-selected', 'false');
            });
            const activeBtn = document.getElementById('tab' + tab);
            activeBtn.classList.add('active');
            activeBtn.setAttribute('aria-selected', 'true');
            
            if(tab === 'Rival') {
                document.getElementById('researchContainer').style.display = 'none';
                document.getElementById('sabotageContainer').style.display = 'block';
                document.getElementById('businessContainer').style.display = 'none';
                document.getElementById('sabWeatherUI').innerText = state.forecast[0];
                document.getElementById('sabThresholdUI').innerText = Math.min(50, state.sabotageSuccesses * 10);
            } else if (tab === 'Business') {
                document.getElementById('researchContainer').style.display = 'none';
                document.getElementById('sabotageContainer').style.display = 'none';
                document.getElementById('businessContainer').style.display = 'block';
                renderBusinessContent();
            } else {
                document.getElementById('researchContainer').style.display = 'grid';
                document.getElementById('sabotageContainer').style.display = 'none';
                document.getElementById('businessContainer').style.display = 'none';
                renderResearchContent();
            }
        }

        function renderBusinessContent() {
            const container = document.getElementById('businessContainer');
            let isPurchased = state.unlocked.marketResearch || false;
            let isFBPurchased = state.unlocked.financialBreakdown || false;
            let html = `
                <h2 style="color:#2980B9; margin-top:0; text-align:center;">📈 Business Upgrades</h2>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; text-align: left;">
                    <div style="background: white; padding: 15px; border-radius: 8px; border: 2px solid #D4E6F1;">
                        <h4 style="margin-top:0; color:#2980B9;">🧾 Basic Accounting</h4>
                        <p style="font-size:0.85em; color:#4A3B32;">Unlock the daily <strong>Financial Breakdown</strong> on your closing report to see exactly what you spent on ingredients and rent.</p>
                        <button class="action-btn" style="background: ${isFBPurchased ? '#5C6A6B' : '#2980B9'}; padding: 10px; font-size: 0.9em;" onclick="buyFinancialBreakdown()" ${isFBPurchased ? 'disabled' : ''}>
                            ${isFBPurchased ? '✔️ Purchased' : 'Buy Upgrade ($50)'}
                        </button>
                    </div>
                    <div style="background: white; padding: 15px; border-radius: 8px; border: 2px solid #D4E6F1;">
                        <h4 style="margin-top:0; color:#2980B9;">📊 Market Research</h4>
                        <p style="font-size:0.85em; color:#4A3B32;">Split your "Walkaways" metric into two specific categories: <strong>Taste too low</strong> vs. <strong>Price too high</strong>.</p>
                        <button class="action-btn" style="background: ${isPurchased ? '#5C6A6B' : '#2980B9'}; padding: 10px; font-size: 0.9em;" onclick="buyMarketResearch()" ${isPurchased ? 'disabled' : ''}>
                            ${isPurchased ? '✔️ Purchased' : 'Buy Upgrade ($200)'}
                        </button>
                    </div>
                </div>`;
            container.innerHTML = html;
        }

        function buyFinancialBreakdown() {
            if (state.bank >= 50) { state.bank -= 50; state.unlocked.financialBreakdown = true; updateUI(); renderBusinessContent(); }
            else { alert("Insufficient funds!"); }
        }

        function buyMarketResearch() {
            if (state.bank >= 200) { state.bank -= 200; state.unlocked.marketResearch = true; updateUI(); renderBusinessContent(); }
            else { alert("Insufficient funds!"); }
        }

        function renderResearchContent() {
            const container = document.getElementById('researchContainer');
            const items = [{id:'t', n:'Temperature'}, {id:'s', n:'Sweetness'}, {id:'i', n:'Intensity'}];
            let html = '';
            items.forEach(it => {
                const tiers = state.unlocked[state.activeResearchTab][it.id]; 
                const math = state.weatherData[state.activeResearchTab][it.id];
                html += `<div class="research-item">
                    <h3 style="text-align:center; margin-top:0;">${it.n} Upgrades</h3>
                    <button class="tier-btn" onclick="buyResearch('${it.id}', 2, 150)" ${tiers[2]?'disabled':''}>Symmetry ($150)</button>
                    ${tiers[2] ? `<table class="data-table" style="border: 2px dashed #C0392B;"><tr><th scope="col">(x)</th><th scope="col">(y)</th></tr><tr><td>${math.symPoints[0].x}</td><td>${math.symPoints[0].y}</td></tr><tr><td>${math.symPoints[1].x}</td><td>${math.symPoints[1].y}</td></tr></table>` : ''}
                    <button class="tier-btn" onclick="buyResearch('${it.id}', 3, 600)" ${tiers[3]?'disabled':''}>Standard ($600)</button>
                    ${tiers[3] ? `<div class="reveal-math">y = ${math.std}</div>` : ''}
                    <button class="tier-btn" onclick="buyResearch('${it.id}', 4, 2400)" ${tiers[4]?'disabled':''}>Vertex ($2.4k)</button>
                    ${tiers[4] ? `<div class="reveal-math">y = ${math.a}(x - ${math.h})² + ${math.k}</div>` : ''}
                </div>`;
            });
            container.innerHTML = html;
        }

        function updateMainObservations() {
            const wType = state.forecast[0];
            document.getElementById('obsWeatherUI').innerText = wType;
            const container = document.getElementById('mainScreenObs');
            const items = [{id:'t', n:'Temperature'}, {id:'s', n:'Sweetness'}, {id:'i', n:'Intensity'}];
            let daysRevealed = Math.min(state.day, 3);
            let html = '';
            items.forEach(it => {
                const math = state.weatherData[wType][it.id];
                let rows = '';
                for(let i=0; i<daysRevealed; i++) { rows += `<tr><td>${math.secantPoints[i].x}</td><td>${math.secantPoints[i].y}</td></tr>`; }
                html += `<div>
                    <div style="font-size:0.85em; font-weight:bold; text-align:center; color:#5D4037; margin-bottom:4px;">${it.n}</div>
                    <table class="data-table" style="margin-bottom:0;"><tr><th scope="col">(x)</th><th scope="col">(y)</th></tr>${rows}</table>
                </div>`;
            });
            container.innerHTML = html;
        }

        function buyResearch(ing, tier, cost) {
            if (state.bank >= cost) { state.bank -= cost; state.unlocked[state.activeResearchTab][ing][tier] = true; updateUI(); renderResearchContent(); }
            else { alert("Insufficient funds!"); }
        }

        function calculatePlayerResults(wType, w) {
            let t = parseFloat(document.getElementById('tSlider').value); 
            let s = parseFloat(document.getElementById('sSlider').value); 
            let i = parseFloat(document.getElementById('iSlider').value); 
            let p = parseFloat(document.getElementById('pVal').value) || 0;
            let tScore = w.t.a * Math.pow(t - w.t.h, 2) + w.t.k;
            let sScore = w.s.a * Math.pow(s - w.s.h, 2) + w.s.k;
            let iScore = w.i.a * Math.pow(i - w.i.h, 2) + w.i.k;
            let taste = Math.max(0, Math.round(tScore + sScore + iScore));
            let pot = Math.round((taste * w.demand * 1.5) + (wType==='Heatwave'?60:15)) + (state.buzzStreak * 5);
            if (state.snobBlogBuff > 0) pot += state.snobBlogBuff;
            if (state.badBlogActive) { pot -= 30; if(pot < 0) pot = 0; }
            if (state.priceGougeActive) { pot -= 150; if(pot < 0) pot = 0; }
            let conversion = Math.max(0, (taste - (p * w.sens)) / 100);
            let triggeredPriceGouge = false;
            let sales = 0;
            let base_taste_conv = Math.min(1.0, taste / 100);
            if (wType === 'Heatwave') { base_taste_conv = Math.max(0.15, base_taste_conv); }
            let base_taste_sales = Math.round(pot * base_taste_conv);
            let walkawaysTaste = pot - base_taste_sales;
            let walkawaysPrice = 0;
            if (p > 20) { triggeredPriceGouge = true; sales = 0; walkawaysPrice = base_taste_sales; } 
            else { sales = Math.min(pot, Math.round(pot * (wType==='Heatwave' ? Math.max(0.15, conversion) : conversion))); walkawaysPrice = base_taste_sales - sales; }
            let walkaways = pot - sales;
            let baseCost = (t * 0.1) + (s * 0.2);
            let totalBeansNeeded = sales * i;
            let ingredientsCost = 0;
            let beansUsed = 0;
            if (state.bulkBeans >= totalBeansNeeded) { ingredientsCost = (baseCost * sales) + (totalBeansNeeded * 0.20); beansUsed = totalBeansNeeded; } 
            else { let normalUsed = totalBeansNeeded - state.bulkBeans; ingredientsCost = (baseCost * sales) + (state.bulkBeans * 0.20) + (normalUsed * state.ingredientCost); beansUsed = state.bulkBeans; }
            let revenue = p * sales;
            let totalExpenses = ingredientsCost + state.rent;
            let net = revenue - totalExpenses;
            let donorCover = 0;
            if (state.day <= 4 && net < 0) { donorCover = Math.abs(net); net = 0; }
            if (taste >= 75 && net > 0) { state.buzzStreak++; if(state.buzzStreak > state.maxBuzz) state.maxBuzz = state.buzzStreak; } 
            else { state.buzzStreak = 0; }
            let tempSnobStreak = state.snobRainyStreak;
            let nextBlogBuff = 0;
            let triggeredBadBlog = false;
            if (wType === "Rainy") {
                if (taste >= 85) { 
                    tempSnobStreak++; 
                    if (tempSnobStreak >= 3) { 
                        let maxTaste = Math.round(w.t.k + w.s.k + w.i.k);
                        if (taste >= maxTaste - 2) { nextBlogBuff = 120; } 
                        else { nextBlogBuff = 50; }
                    } 
                } 
                else { tempSnobStreak = 0; if (taste < 40) triggeredBadBlog = true; }
            }
            let quote = "";
            if (triggeredPriceGouge) quote = `"Are you out of your mind?! I'm taking a picture of this price menu to the local news!" - Outraged Citizen`;
            else if (state.priceGougeActive && sales === 0) quote = `"I only came by to boo you for price gouging. Booooo!" - Angry Protester`;
            else if (sales === 0 && p < 20) quote = `"Nobody is paying $${p.toFixed(2)} for this. We're going to the chain store." - Angry Local`;
            else if (taste < 40) quote = `"Did you accidentally brew the coffee filters instead of the beans? Yuck." - Disgusted Mayor`;
            else if (nextBlogBuff === 120) quote = `"THREE FLAWLESS RAINY DAYS! I'm giving this place my highest rating ever! The internet is going to explode!" - Elite Coffee Snob`;
            else if (nextBlogBuff === 50) quote = `"Three good rainy days in a row! I'm going to write a solid blog post about this place right now!" - Local Coffee Snob`;
            else if (wType === "Rainy" && taste >= 85 && (tempSnobStreak === 1 || tempSnobStreak === 2)) quote = `"This is surprisingly perfect for a rainy day... if you keep this up, I'll post it on my blog!" - Local Coffee Snob`;
            else if (taste >= 55 && taste <= 82) {
                const midQuotes = [`"It's a fine cup of joe, but I wouldn't go out of my way for it." - Local Customer`, `"Good, but not 'wow' good. Something is slightly off with the recipe." - Local Customer`, `"It's decent coffee, but I expected a bit more punch." - Local Customer`];
                quote = midQuotes[Math.floor(Math.random() * midQuotes.length)];
            } 
            else if (conversion < 0.3 && taste > 80) quote = `"The coffee is incredible, but my wallet is screaming at these prices." - Frugal Regular`;
            else quote = `"This is great coffee! I bet you're getting close to a perfect batch." - Happy Regular`;
            return { net, taste, pot, walkaways, walkawaysTaste, walkawaysPrice, sales, quote, donorCover, beansUsed, nextBlogBuff, triggeredBadBlog, tempSnobStreak, triggeredPriceGouge, revenue, ingredientsCost, rent: state.rent, totalExpenses };
        }

        function processSabotage(wType, w) {
            let sabTemp = parseFloat(document.getElementById('sabotageTemp').value) || 0;
            let baseIncome = (wType === "Sunny" ? 250 : wType === "Heatwave" ? 350 : 150) + state.rivalMomentum;
            if (sabTemp === 0) return { net: baseIncome, msg: "" };
            let sabTaste = w.t.a * Math.pow(sabTemp - w.t.h, 2) + w.t.k;
            let minTasteRequired = Math.min(50, state.sabotageSuccesses * 10);
            if (sabTaste <= minTasteRequired) { return { net: baseIncome, msg: `❌ Rejected! They didn't believe the recipe.` }; } 
            else if (sabTemp === w.t.h) { return { net: baseIncome * 2.5, msg: `😱 You gave them the vertex! They made maximum profit!` }; } 
            else { let scalingFactor = sabTaste / w.t.k; let loss = baseIncome * scalingFactor - (100 * (1-scalingFactor)); state.sabotageSuccesses++; return { net: loss, msg: `✅ Sabotage successful! They brewed a bad batch.` }; }
        }

        function playCamAnimation(pResult, wType, tSliderVal) {
            const cam = document.getElementById('camScreen');
            cam.innerHTML = '<div class="cam-label">🔴 REC</div>';
            let numCustomers = Math.min(12, Math.ceil(pResult.pot / 10)); if (numCustomers === 0) numCustomers = 3; 
            for(let i=0; i<numCustomers; i++) {
                setTimeout(() => {
                    let cust = document.createElement('div'); cust.className = 'emoji-customer'; cust.setAttribute('aria-hidden', 'true');
                    let reaction = ''; let animName = 'walkAcross';
                    if (pResult.triggeredPriceGouge) { cust.innerText = '🚶‍♂️'; reaction = '🛑'; animName = 'walkInAndLeave'; }
                    else if (pResult.taste < 40) { cust.innerText = '🤢'; reaction = '🤮'; animName = 'walkInAndLeave'; } 
                    else if (pResult.walkaways > pResult.sales) { cust.innerText = '🚶‍♂️'; reaction = '💸'; animName = 'walkInAndLeave'; } 
                    else if (wType === "Heatwave" && tSliderVal > 4) { cust.innerText = '🥵'; reaction = '🔥'; animName = 'walkInAndLeave'; } 
                    else if (wType === "Rainy" && tSliderVal < 4) { cust.innerText = '🥶'; reaction = '🧊'; animName = 'walkInAndLeave'; } 
                    else { cust.innerText = ['🚶','🏃','🧍'][Math.floor(Math.random()*3)]; reaction = ['☕','😍','🤑'][Math.floor(Math.random()*3)]; animName = 'walkAcross'; }
                    cust.style.animationName = animName; cust.style.animationDuration = (1.5 + Math.random()) + 's';
                    if(reaction) {
                        let reactEl = document.createElement('div'); reactEl.className = 'emoji-reaction'; reactEl.innerText = reaction;
                        reactEl.style.animationDelay = (0.5 + Math.random()) + 's'; reactEl.style.animationName = 'floatUp';
                        reactEl.style.animationDuration = '1s'; reactEl.style.animationFillMode = 'forwards'; cust.appendChild(reactEl);
                    }
                    cam.appendChild(cust);
                }, Math.random() * 800);
            }
        }

        function closeShop() {
            document.getElementById('sellBtn').disabled = true; document.getElementById('closeBtn').disabled = true;
            const wType = state.forecast[0];
            let rNet = (wType === "Sunny" ? 250 : wType === "Heatwave" ? 350 : 150) + state.rivalMomentum;
            let pNet = -state.rent; let donor = 0;
            if (state.day <= 4 && pNet < 0) { donor = Math.abs(pNet); pNet = 0; }
            document.getElementById('modalRev').innerText = `$0.00`; document.getElementById('modalIngCost').innerText = `-$0.00`; document.getElementById('modalRentCost').innerText = `-$${state.rent.toFixed(2)}`; document.getElementById('modalTotalExp').innerText = `-$${state.rent.toFixed(2)}`;
            state.bank += pNet; state.rivalBank += rNet;
            state.ledgerData.push({d: state.day, w: wType, recipe: '-', t: '-', p: 0, n: pNet, r: rNet});
            state.snobRainyStreak = 0; state.snobBlogBuff = 0; state.badBlogActive = false; state.priceGougeActive = false;
            document.getElementById('modalWeather').innerText = `Day ${state.day} - ${wType} (CLOSED)`; document.getElementById('modalQuote').innerText = `"A closed sign? But I need my caffeine!" - Disappointed Regular`; document.getElementById('modalTaste').innerText = "-"; document.getElementById('modalPot').innerText = "0";
            document.getElementById('walkawayStandard').style.display = 'flex'; document.getElementById('walkawayAdvancedTaste').style.display = 'none'; document.getElementById('walkawayAdvancedPrice').style.display = 'none';
            document.getElementById('modalWalk').innerText = "0"; document.getElementById('modalSales').innerText = "0";
            if (donor > 0) { document.getElementById('modalDonorRow').style.display = 'flex'; document.getElementById('modalDonor').innerText = `+$${donor.toFixed(2)}`; } 
            else { document.getElementById('modalDonorRow').style.display = 'none'; }
            document.getElementById('modalNet').innerText = `$${pNet.toFixed(2)}`; document.getElementById('modalNet').className = pNet >= 0 ? 'pos large-text' : 'neg large-text';
            document.getElementById('modalRivalNet').innerText = `$${rNet.toFixed(2)}`; document.getElementById('sabotageResult').innerText = "Shop closed. No espionage conducted today.";
            document.getElementById('modalSnobBlog').style.display = 'none'; document.getElementById('modalBadBlog').style.display = 'none'; document.getElementById('modalPriceGouge').style.display = 'none';
            document.getElementById('financialBreakdown').style.display = 'none'; document.getElementById('toggleBreakdownBtn').style.display = state.unlocked.financialBreakdown ? 'block' : 'none';
            document.getElementById('toggleBreakdownBtn').innerText = '📊 Show Financial Breakdown'; document.getElementById('toggleBreakdownBtn').setAttribute('aria-expanded', 'false');
            toggleModal('reportModal', true); document.getElementById('sellBtn').disabled = false; document.getElementById('closeBtn').disabled = false;
        }

        function executeTurn() {
            document.getElementById('sellBtn').disabled = true; document.getElementById('sellBtn').innerText = "BREWING..."; document.getElementById('closeBtn').disabled = true;
            const wType = state.forecast[0]; const w = state.weatherData[wType];
            let t = parseFloat(document.getElementById('tSlider').value); let s = parseFloat(document.getElementById('sSlider').value); let i = parseFloat(document.getElementById('iSlider').value); 
            let pResult = calculatePlayerResults(wType, w);
            let rResult = processSabotage(wType, w);

            let maxTaste = Math.round(w.t.k + w.s.k + w.i.k);
            if (!state.dayPerfectRecipe && pResult.taste >= maxTaste) { state.dayPerfectRecipe = state.day; }
            if (!state.dayPerfectPrice && pResult.taste >= maxTaste && pResult.walkawaysPrice === 0 && pResult.sales > 0) { state.dayPerfectPrice = state.day; }

            playCamAnimation(pResult, wType, t);
            setTimeout(() => {
                document.getElementById('sellBtn').disabled = false; document.getElementById('sellBtn').innerText = "BREW & OPEN"; document.getElementById('closeBtn').disabled = false;
                document.getElementById('modalRev').innerText = `$${pResult.revenue.toFixed(2)}`; document.getElementById('modalIngCost').innerText = `-$${pResult.ingredientsCost.toFixed(2)}`; document.getElementById('modalRentCost').innerText = `-$${pResult.rent.toFixed(2)}`; document.getElementById('modalTotalExp').innerText = `-$${pResult.totalExpenses.toFixed(2)}`;
                document.getElementById('sabotageTemp').value = 0; document.getElementById('modalWeather').innerText = `Day ${state.day} - ${wType} (${w.tempStr})`;
                document.getElementById('modalQuote').innerText = pResult.quote; document.getElementById('modalTaste').innerText = pResult.taste; document.getElementById('modalPot').innerText = pResult.pot;
                if (state.unlocked.marketResearch) {
                    document.getElementById('walkawayStandard').style.display = 'none'; document.getElementById('walkawayAdvancedTaste').style.display = 'flex'; document.getElementById('walkawayAdvancedPrice').style.display = 'flex';
                    document.getElementById('modalWalkTaste').innerText = pResult.walkawaysTaste; document.getElementById('modalWalkPrice').innerText = pResult.walkawaysPrice;
                } else { document.getElementById('walkawayStandard').style.display = 'flex'; document.getElementById('walkawayAdvancedTaste').style.display = 'none'; document.getElementById('walkawayAdvancedPrice').style.display = 'none'; document.getElementById('modalWalk').innerText = pResult.walkaways; }
                document.getElementById('modalSales').innerText = pResult.sales;
                if (pResult.donorCover > 0) { document.getElementById('modalDonorRow').style.display = 'flex'; document.getElementById('modalDonor').innerText = `+$${pResult.donorCover.toFixed(2)}`; } 
                else { document.getElementById('modalDonorRow').style.display = 'none'; }
                document.getElementById('modalNet').innerText = `$${pResult.net.toFixed(2)}`; document.getElementById('modalNet').className = pResult.net >= 0 ? 'pos large-text' : 'neg large-text';
                document.getElementById('modalRivalNet').innerText = `$${rResult.net.toFixed(2)}`; document.getElementById('sabotageResult').innerText = rResult.msg;
                state.bulkBeans -= pResult.beansUsed; if (state.bulkBeans < 0) state.bulkBeans = 0;
                state.snobRainyStreak = pResult.tempSnobStreak;
                if (pResult.nextBlogBuff === 120) { document.getElementById('modalSnobBlog').innerHTML = '🌟 VIRAL MASTERPIECE! A coffee snob declared your rainy day brew ABSOLUTELY PERFECT! Expect a MASSIVE line tomorrow!'; document.getElementById('modalSnobBlog').style.background = '#F9E79F'; document.getElementById('modalSnobBlog').style.color = '#7D6608'; document.getElementById('modalSnobBlog').style.borderColor = '#D4AC0D'; document.getElementById('modalSnobBlog').style.display = 'block'; } 
                else if (pResult.nextBlogBuff === 50) { document.getElementById('modalSnobBlog').innerHTML = '☕ A local coffee snob loved your consistent rainy day brews! Their review went live! Expect a rush!'; document.getElementById('modalSnobBlog').style.background = '#E8DAEF'; document.getElementById('modalSnobBlog').style.color = '#6C3483'; document.getElementById('modalSnobBlog').style.borderColor = '#9B59B6'; document.getElementById('modalSnobBlog').style.display = 'block'; } 
                else { document.getElementById('modalSnobBlog').style.display = 'none'; }
                if (pResult.nextBlogBuff > 0) state.snobRainyStreak = 0;
                document.getElementById('modalBadBlog').style.display = pResult.triggeredBadBlog ? 'block' : 'none'; document.getElementById('modalPriceGouge').style.display = pResult.triggeredPriceGouge ? 'block' : 'none';
                state.snobBlogBuff = pResult.nextBlogBuff; state.badBlogActive = pResult.triggeredBadBlog; state.priceGougeActive = pResult.triggeredPriceGouge;
                state.bank += pResult.net; state.rivalBank += rResult.net;
                state.ledgerData.push({d: state.day, w: wType, recipe: `(${t}, ${s}, ${i})`, t: pResult.taste, p: pResult.pot, n: pResult.net, r: rResult.net});
                document.getElementById('financialBreakdown').style.display = 'none'; document.getElementById('toggleBreakdownBtn').style.display = state.unlocked.financialBreakdown ? 'block' : 'none';
                document.getElementById('toggleBreakdownBtn').innerText = '📊 Show Financial Breakdown'; document.getElementById('toggleBreakdownBtn').setAttribute('aria-expanded', 'false');
                toggleModal('reportModal', true);
            }, 2500);
        }

        function checkWinLoss() {
            if (state.bank >= 15000) { 
                document.getElementById('winDays').innerText = state.day;
                document.getElementById('winRecipeDay').innerText = state.dayPerfectRecipe ? `Day ${state.dayPerfectRecipe}` : "N/A";
                document.getElementById('winPriceDay').innerText = state.dayPerfectPrice ? `Day ${state.dayPerfectPrice}` : "N/A";
                toggleModal('winModal', true);
            } else if (state.rivalBank >= 15000) { 
                toggleModal('lossModal', true); 
            }
        }

        function closeDailyReport() {
            toggleModal('reportModal', false);
            if (state.bulkBeans > 0) {
                state.bulkDays--;
                if (state.bulkDays <= 0) { alert(`🗑️ Your remaining ${Math.floor(state.bulkBeans)} bulk beans went stale!`); state.bulkBeans = 0; }
            }
            checkWinLoss();
            state.forecast.shift(); state.forecast.push(["Sunny","Heatwave","Rainy"][Math.floor(Math.random()*3)]);
            state.day++; state.rivalMomentum += 2; 
            document.getElementById('camScreen').innerHTML = '<div class="cam-label">🔴 REC</div>';
            updateUI();
        }

        function updateUI() {
            if (typeof state.unlocked.marketResearch === 'undefined') state.unlocked.marketResearch = false;
            if (typeof state.unlocked.financialBreakdown === 'undefined') state.unlocked.financialBreakdown = false;
            document.getElementById('bankUI').innerText = `$${state.bank.toFixed(2)}`; document.getElementById('rivalBankUI').innerText = `$${state.rivalBank.toFixed(2)}`;
            document.getElementById('roundUI').innerText = state.day; document.getElementById('buzzUI').innerText = state.buzzStreak * 5;
            document.getElementById('beanInvUI').innerText = `${Math.floor(state.bulkBeans)} units`; document.getElementById('beanDaysUI').innerText = state.bulkBeans > 0 ? `${state.bulkDays} days` : '-';
            document.getElementById('fillPlayer').style.width = Math.min(100, (state.bank/state.winGoal*100)) + '%'; document.getElementById('fillRival').style.width = Math.min(100, (state.rivalBank/state.winGoal*100)) + '%';
            const bar = document.getElementById('forecastBar'); bar.innerHTML = '';
            state.forecast.forEach((type, idx) => {
                const dayDiv = document.createElement('div'); dayDiv.className = `forecast-day ${idx === 0 ? 'active' : ''}`;
                dayDiv.innerHTML = `${type === "Sunny" ? "☀️" : type === "Heatwave" ? "🔥" : "🌧️"}<br>${type}<span style="font-size:0.7em; display:block; margin-top:4px;">${state.weatherData[type].tempStr}</span>`;
                bar.appendChild(dayDiv);
            });
            updateMainObservations(); renderLedger(); updateCalculations();
            if(state.day <= 4) document.getElementById('trainingBanner').style.display = 'block'; else document.getElementById('trainingBanner').style.display = 'none';
        }

        function renderLedger() {
            const tbody = document.getElementById('ledgerBody'); tbody.innerHTML = '';
            let sortedData = [...state.ledgerData].sort((a, b) => {
                let valA = a[state.sortCol]; let valB = b[state.sortCol];
                if (state.sortCol === 't') { valA = valA === '-' ? -1 : valA; valB = valB === '-' ? -1 : valB; }
                return state.sortAsc ? valA - valB : valB - valA;
            });
            sortedData.forEach(r => { tbody.innerHTML += `<tr><td>${r.d}</td><td>${r.w}</td><td>${r.recipe}</td><td>${r.t}</td><td>${r.p}</td><td class="${r.n>=0?'pos':'neg'}">$${r.n.toFixed(2)}</td><td style="color:#C0392B;">$${r.r.toFixed(2)}</td></tr>`; });
        }

        function sortLedger(col) { if (state.sortCol === col) state.sortAsc = !state.sortAsc; else { state.sortCol = col; state.sortAsc = false; } renderLedger(); }
        function buyBulkBeans() { if(state.bank >= 100) { state.bank -= 100; state.bulkBeans += 500; state.bulkDays = 5; updateUI(); } else { alert("Not enough money!");} }
        
        function saveGame() { 
            try {
                localStorage.setItem('coffeeLabSave', JSON.stringify(state)); 
                alert("Game Saved!"); 
            } catch (e) {
                alert("Saving is disabled by your browser or school network settings.");
            }
        }
        function loadGame() {
            try {
                const savedData = localStorage.getItem('coffeeLabSave');
                if (savedData) { 
                    let parsed = JSON.parse(savedData);
                    if (typeof parsed.unlocked.Sunny.t === 'number') { localStorage.removeItem('coffeeLabSave'); hardReset(); return; }
                    state = { ...state, ...parsed }; updateUI(); alert('Game loaded!'); 
                } 
            } catch (e) {
                console.warn("Local storage is blocked.");
            }
        }
        function newGame() { 
            if(confirm("Restart game?")) { 
                try { localStorage.removeItem('coffeeLabSave'); } catch(e){} 
                hardReset(); 
            } 
        }

        function updateCalculations() {
            let t = parseFloat(document.getElementById('tSlider').value); let s = parseFloat(document.getElementById('sSlider').value); let i = parseFloat(document.getElementById('iSlider').value); let p = parseFloat(document.getElementById('pVal').value) || 0;
            document.getElementById('tLabel').innerText = t.toFixed(1); document.getElementById('sLabel').innerText = s.toFixed(1); document.getElementById('iLabel').innerText = i.toFixed(1);
            let currentBeanRate = state.bulkBeans > 0 ? 0.20 : state.ingredientCost;
            let unitCost = (t*0.1) + (s*0.2) + (i*currentBeanRate); let margin = p - unitCost;
            document.getElementById('unitCostUI').innerText = `$${unitCost.toFixed(2)}`; document.getElementById('unitMarginUI').innerText = `$${margin.toFixed(2)}`;
            document.getElementById('unitMarginUI').className = margin >= 0 ? 'pos' : 'neg';
        }
        loadGame(); if(state.day === 1) { initializeGame(); }
    </script>
</body>
